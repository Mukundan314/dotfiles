font:
  size: 9.0
  normal:
    family: Source Code Pro

colors:
  primary:
    background: '{{ .colors.background }}'
    foreground: '{{ .colors.foreground }}'

  normal:
    black:   '{{ .colors.color_0 }}'
    red:     '{{ .colors.color_1 }}'
    green:   '{{ .colors.color_2 }}'
    yellow:  '{{ .colors.color_3 }}'
    blue:    '{{ .colors.color_4 }}'
    magenta: '{{ .colors.color_5 }}'
    cyan:    '{{ .colors.color_6 }}'
    white:   '{{ .colors.color_7 }}'

  bright:
    black:   '{{ .colors.color_8 }}'
    red:     '{{ .colors.color_9 }}'
    green:   '{{ .colors.color_10 }}'
    yellow:  '{{ .colors.color_11 }}'
    blue:    '{{ .colors.color_12 }}'
    magenta: '{{ .colors.color_13 }}'
    cyan:    '{{ .colors.color_14 }}'
    white:   '{{ .colors.color_15 }}'

  {{ if (hasPrefix .colorscheme "gruvbox")}}
  indexed_colors:
    - { index: 234, color: '#1d2021' }
    - { index: 235, color: '#282828' }
    - { index: 236, color: '#32302f' }
    - { index: 237, color: '#3c3836' }
    - { index: 239, color: '#504945' }
    - { index: 241, color: '#665c54' }
    - { index: 243, color: '#7c6f64' }
    - { index: 245, color: '#928374' }
    - { index: 244, color: '#928374' }
    - { index: 230, color: '#f9f5d7' }
    - { index: 229, color: '#fbf1c7' }
    - { index: 228, color: '#f2e5bc' }
    - { index: 223, color: '#ebdbb2' }
    - { index: 250, color: '#d5c4a1' }
    - { index: 248, color: '#bdae93' }
    - { index: 246, color: '#a89984' }
    - { index: 167, color: '#fb4934' }
    - { index: 142, color: '#b8bb26' }
    - { index: 214, color: '#fabd2f' }
    - { index: 109, color: '#83a598' }
    - { index: 175, color: '#d3869b' }
    - { index: 108, color: '#8ec07c' }
    - { index: 208, color: '#fe8019' }
    - { index: 124, color: '#cc241d' }
    - { index: 106, color: '#98971a' }
    - { index: 172, color: '#d79921' }
    - { index:  66, color: '#458588' }
    - { index: 132, color: '#b16286' }
    - { index:  72, color: '#689d6a' }
    - { index: 166, color: '#d65d0e' }
    - { index:  88, color: '#9d0006' }
    - { index: 100, color: '#79740e' }
    - { index: 136, color: '#b57614' }
    - { index:  24, color: '#076678' }
    - { index:  96, color: '#8f3f71' }
    - { index:  66, color: '#427b58' }
    - { index: 130, color: '#af3a03' }
  {{ else if (eq .colorscheme "nord")}}
  dim:
    black: '#373e4d'
    red: '#94545d'
    green: '#809575'
    yellow: '#b29e75'
    blue: '#68809a'
    magenta: '#8c738c'
    cyan: '#6d96a5'
    white: '#aeb3bb'

  cursor:
    text: '#2e3440'
    cursor: '#d8dee9'

  vi_mode_cursor:
    text: '#2e3440'
    cursor: '#d8dee9'

  selection:
    text: CellForeground
    background: '#4c566a'

  search:
    matches:
      foreground: CellBackground
      background: '#88c0d0'
    bar:
      background: '#434c5e'
      foreground: '#d8dee9'
  {{ else if (eq .colorscheme "dracula")}}
  cursor:
    text: '#44475a'
    cursor: '#f8f8f2'

  selection:
    text: '#f8f8f2'
    background: '#44475a'

  dim:
    black:   '#14151b'
    red:     '#ff2222'
    green:   '#1ef956'
    yellow:  '#ebf85b'
    blue:    '#4d5b86'
    magenta: '#ff46b0'
    cyan:    '#59dffc'
    white:   '#e6e6d1'
  {{ end }}
