ZDOTDIR=$HOME

declare -A ZINIT
ZINIT[HOME_DIR]=$HOME/.zinit
ZINIT[BIN_DIR]=${ZINIT[HOME_DIR]}/bin

export BROWSER=firefox
export EDITOR=vi
export TERMINAL=alacritty
export VISUAL=nvim

export GOPATH=$(go env GOPATH)

export MOZ_ENABLE_WAYLAND=1

typeset -U PATH path
path=(
    "$HOME/bin" "$HOME/.local/bin" "$GOPATH/bin" "$(npm prefix -g)/bin"
    "$(ruby -e 'puts Gem.user_dir')/bin" "$path[@]"
)
export PATH
